-- Customers table
CREATE TABLE customers (
    customer_id INT(11) PRIMARY KEY AUTO_INCREMENT,
    customer_code VARCHAR(50) UNIQUE NOT NULL,
    first_name VARCHAR(100) NOT NULL,
    last_name VARCHAR(100) NOT NULL,
    gender ENUM('male', 'female', 'other', 'prefer-not-to-say') DEFAULT 'other',
    date_of_birth DATE,
    national_id VARCHAR(50),
    email VARCHAR(100),
    phone VARCHAR(20) NOT NULL,
    alternate_phone VARCHAR(20),
    address TEXT,
    city VARCHAR(100),
    region VARCHAR(100),
    blood_group ENUM('a+', 'a-', 'b+', 'b-', 'ab+', 'ab-', 'o+', 'o-', 'unknown') DEFAULT 'unknown',
    allergies TEXT,
    medical_conditions TEXT,
    current_medications TEXT,
    customer_type ENUM('regular', 'premium', 'wholesale', 'corporate', 'government') DEFAULT 'regular',
    registration_date DATE NOT NULL,
    referred_by VARCHAR(100),
    loyalty_points INT(11) DEFAULT 0,
    total_visits INT(11) DEFAULT 0,
    total_spent DECIMAL(12,2) DEFAULT 0.00,
    last_visit DATE,
    status ENUM('active', 'inactive', 'pending', 'suspended') DEFAULT 'active',
    preferred_communication ENUM('email', 'sms', 'phone', 'whatsapp', 'all') DEFAULT 'email',
    notes TEXT,
    branch_id INT(11),
    created_by INT(11),
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,
    FOREIGN KEY (branch_id) REFERENCES branches(branch_id),
    FOREIGN KEY (created_by) REFERENCES users(user_id),
    INDEX idx_customer_code (customer_code),
    INDEX idx_status (status),
    INDEX idx_customer_type (customer_type),
    INDEX idx_city (city),
    INDEX idx_phone (phone),
    INDEX idx_email (email)
);

-- Customer prescriptions table
CREATE TABLE customer_prescriptions (
    prescription_id INT(11) PRIMARY KEY AUTO_INCREMENT,
    customer_id INT(11) NOT NULL,
    doctor_name VARCHAR(100),
    diagnosis TEXT,
    prescription_date DATE NOT NULL,
    valid_until DATE,
    notes TEXT,
    status ENUM('active', 'completed', 'cancelled', 'expired') DEFAULT 'active',
    created_by INT(11),
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,
    FOREIGN KEY (customer_id) REFERENCES customers(customer_id),
    FOREIGN KEY (created_by) REFERENCES users(user_id)
);

-- Prescription items table
CREATE TABLE prescription_items (
    item_id INT(11) PRIMARY KEY AUTO_INCREMENT,
    prescription_id INT(11) NOT NULL,
    medicine_id INT(11),
    medicine_name VARCHAR(255),
    dosage VARCHAR(100),
    frequency VARCHAR(100),
    duration VARCHAR(100),
    instructions TEXT,
    quantity INT(11),
    status ENUM('pending', 'dispensed', 'cancelled') DEFAULT 'pending',
    FOREIGN KEY (prescription_id) REFERENCES customer_prescriptions(prescription_id),
    FOREIGN KEY (medicine_id) REFERENCES medicines(medicine_id)
);

-- Customer visits/transactions table
CREATE TABLE customer_visits (
    visit_id INT(11) PRIMARY KEY AUTO_INCREMENT,
    customer_id INT(11) NOT NULL,
    visit_date DATE NOT NULL,
    invoice_number VARCHAR(50),
    total_amount DECIMAL(12,2) DEFAULT 0.00,
    payment_method ENUM('cash', 'card', 'mobile_money', 'insurance', 'credit') DEFAULT 'cash',
    payment_status ENUM('paid', 'partial', 'pending', 'cancelled') DEFAULT 'paid',
    notes TEXT,
    created_by INT(11),
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    FOREIGN KEY (customer_id) REFERENCES customers(customer_id),
    FOREIGN KEY (created_by) REFERENCES users(user_id),
    INDEX idx_visit_date (visit_date),
    INDEX idx_invoice (invoice_number)
);

-- Customer files/documents table
CREATE TABLE customer_files (
    file_id INT(11) PRIMARY KEY AUTO_INCREMENT,
    customer_id INT(11) NOT NULL,
    file_type ENUM('prescription', 'lab_report', 'id_copy', 'insurance', 'other') DEFAULT 'other',
    file_name VARCHAR(255) NOT NULL,
    file_path VARCHAR(500) NOT NULL,
    uploaded_by INT(11),
    uploaded_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    FOREIGN KEY (customer_id) REFERENCES customers(customer_id),
    FOREIGN KEY (uploaded_by) REFERENCES users(user_id)
);



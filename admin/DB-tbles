-- Create medicine categories table
CREATE TABLE medicine_categories (
    category_id INT(11) PRIMARY KEY AUTO_INCREMENT,
    category_code VARCHAR(50) UNIQUE NOT NULL,
    category_name VARCHAR(100) NOT NULL,
    description TEXT,
    parent_category_id INT(11),
    status ENUM('active', 'inactive') DEFAULT 'active',
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,
    FOREIGN KEY (parent_category_id) REFERENCES medicine_categories(category_id)
);

-- Create medicines table
CREATE TABLE medicines (
    medicine_id INT(11) PRIMARY KEY AUTO_INCREMENT,
    medicine_code VARCHAR(50) UNIQUE NOT NULL,
    medicine_name VARCHAR(255) NOT NULL,
    generic_name VARCHAR(255) NOT NULL,
    category_id INT(11),
    dosage_form ENUM('tablet', 'capsule', 'syrup', 'injection', 'ointment', 'cream', 'drops', 'inhaler', 'other') DEFAULT 'tablet',
    strength VARCHAR(100),
    manufacturer VARCHAR(255),
    batch_number VARCHAR(100) NOT NULL,
    barcode VARCHAR(100),
    description TEXT,
    storage_instructions TEXT,
    requires_prescription ENUM('yes', 'no') DEFAULT 'no',
    unit_of_measure VARCHAR(50) DEFAULT 'unit',
    unit_price DECIMAL(10,2) NOT NULL,
    selling_price DECIMAL(10,2) NOT NULL,
    discount_percentage DECIMAL(5,2) DEFAULT 0.00,
    min_stock_level INT(11) DEFAULT 10,
    max_stock_level INT(11) DEFAULT 100,
    current_stock INT(11) DEFAULT 0,
    status ENUM('active', 'inactive', 'discontinued') DEFAULT 'active',
    stock_status ENUM('instock', 'lowstock', 'outofstock', 'expired') DEFAULT 'instock',
    expiry_date DATE NOT NULL,
    purchase_date DATE,
    supplier_id INT(11),
    branch_id INT(11),
    image_path VARCHAR(500),
    created_by INT(11),
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,
    FOREIGN KEY (category_id) REFERENCES medicine_categories(category_id),
    FOREIGN KEY (supplier_id) REFERENCES suppliers(supplier_id),
    FOREIGN KEY (branch_id) REFERENCES branches(branch_id),
    FOREIGN KEY (created_by) REFERENCES users(user_id),
    INDEX idx_category (category_id),
    INDEX idx_supplier (supplier_id),
    INDEX idx_branch (branch_id),
    INDEX idx_expiry (expiry_date),
    INDEX idx_stock_status (stock_status)
);

-- Create inventory_transactions table
CREATE TABLE inventory_transactions (
    transaction_id INT(11) PRIMARY KEY AUTO_INCREMENT,
    medicine_id INT(11) NOT NULL,
    transaction_type ENUM('purchase', 'sale', 'return', 'adjustment', 'transfer', 'expired', 'damaged', 'restock') NOT NULL,
    quantity INT(11) NOT NULL,
    unit_price DECIMAL(10,2),
    total_amount DECIMAL(10,2),
    batch_number VARCHAR(100),
    supplier_id INT(11),
    branch_id INT(11),
    reference_number VARCHAR(100),
    notes TEXT,
    transaction_date DATE NOT NULL,
    expiry_date DATE,
    user_id INT(11) NOT NULL,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    FOREIGN KEY (medicine_id) REFERENCES medicines(medicine_id),
    FOREIGN KEY (supplier_id) REFERENCES suppliers(supplier_id),
    FOREIGN KEY (branch_id) REFERENCES branches(branch_id),
    FOREIGN KEY (user_id) REFERENCES users(user_id),
    INDEX idx_medicine (medicine_id),
    INDEX idx_transaction_type (transaction_type),
    INDEX idx_date (transaction_date)
);

-- Create medicine_batches table
CREATE TABLE medicine_batches (
    batch_id INT(11) PRIMARY KEY AUTO_INCREMENT,
    medicine_id INT(11) NOT NULL,
    batch_number VARCHAR(100) NOT NULL,
    quantity INT(11) NOT NULL,
    remaining_quantity INT(11) NOT NULL,
    unit_price DECIMAL(10,2) NOT NULL,
    expiry_date DATE NOT NULL,
    manufacturer_date DATE,
    supplier_id INT(11),
    purchase_date DATE,
    status ENUM('active', 'expired', 'sold_out', 'damaged') DEFAULT 'active',
    notes TEXT,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,
    FOREIGN KEY (medicine_id) REFERENCES medicines(medicine_id),
    FOREIGN KEY (supplier_id) REFERENCES suppliers(supplier_id),
    INDEX idx_medicine_expiry (medicine_id, expiry_date),
    INDEX idx_batch_number (batch_number),
    UNIQUE KEY unique_batch (medicine_id, batch_number)
);

-- Create stock_alerts table
CREATE TABLE stock_alerts (
    alert_id INT(11) PRIMARY KEY AUTO_INCREMENT,
    medicine_id INT(11) NOT NULL,
    alert_type ENUM('low_stock', 'expired', 'expiring_soon', 'over_stock') NOT NULL,
    alert_level ENUM('warning', 'critical') DEFAULT 'warning',
    message TEXT NOT NULL,
    current_value INT(11) NOT NULL,
    threshold_value INT(11) NOT NULL,
    is_read BOOLEAN DEFAULT FALSE,
    resolved BOOLEAN DEFAULT FALSE,
    resolved_by INT(11),
    resolved_at TIMESTAMP NULL,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    FOREIGN KEY (medicine_id) REFERENCES medicines(medicine_id),
    FOREIGN KEY (resolved_by) REFERENCES users(user_id),
    INDEX idx_alert_type (alert_type),
    INDEX idx_resolved (resolved),
    INDEX idx_medicine (medicine_id)
);

